<!-- =============================================
     JAVASCRIPT
============================================= -->
<script>
  // Footer year
  const yearEl = document.getElementById('footer-year');
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());

  // Email form handler
  function setupForm(
    formId: string,
    emailId: string,
    errorId: string,
    successId: string
  ) {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    const emailInput = document.getElementById(emailId) as HTMLInputElement | null;
    const errorEl = document.getElementById(errorId) as HTMLParagraphElement | null;
    const successEl = document.getElementById(successId) as HTMLDivElement | null;

    if (!form || !emailInput || !errorEl || !successEl) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const email = emailInput.value.trim();
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      if (!email) {
        errorEl.textContent = 'Please enter your email address.';
        emailInput.focus();
        return;
      }

      if (!emailRegex.test(email)) {
        errorEl.textContent = 'Please enter a valid email address.';
        emailInput.focus();
        return;
      }

      // Clear error
      errorEl.textContent = '';

      // Show success state
      form.hidden = true;
      successEl.hidden = false;
    });

    // Clear error on input
    emailInput.addEventListener('input', () => {
      errorEl.textContent = '';
    });
  }

  setupForm('hero-form', 'hero-email', 'hero-form-error', 'hero-form-success');
  setupForm('cta-form', 'cta-email', 'cta-form-error', 'cta-form-success');
</script>

